# ─── OpenRouter (обязательно) ─────────────────────────────────────────────────
# Получить ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# ─── Модели агентов ───────────────────────────────────────────────────────────
# CEO/стратег — нужна сильная модель
# Рабочие модели через OpenRouter:
#   anthropic/claude-opus-4-5       ← лучший выбор для CEO (дороже)
#   anthropic/claude-sonnet-4-5     ← оптимальный баланс
OPENROUTER_AGENTS_MODEL_CEO=anthropic/claude-sonnet-4-5
OPENROUTER_MODEL_CEO=anthropic/claude-sonnet-4-5

# Исполнительные агенты (operations, funnel, content_strategy, rewriter, tech_architect)
OPENROUTER_AGENTS_MODEL_EXECUTOR=anthropic/claude-sonnet-4-5

# ─── Модели для пайплайнов контента ──────────────────────────────────────────
OPENROUTER_TEXT_MODEL=google/gemini-2.0-flash-lite-001
OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-001

# ─── Порт сервера ─────────────────────────────────────────────────────────────
WORKBENCH_API_PORT=8788

# ─── Telegram Tracker ─────────────────────────────────────────────────────────
# TELEGRAM_STATE_PATH=

# ─── FAL AI (генерация изображений) ──────────────────────────────────────────
FAL_KEY=

# ─── Threads (публикация) ─────────────────────────────────────────────────────
THREADS_TOKEN=

# ─── Instagram (публикация каруселей) ────────────────────────────────────────
INSTAGRAM_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=

# ─── Apify (парсинг Instagram) ────────────────────────────────────────────────
APIFY_TOKEN=
APIFY_ACTOR_ID=

# Optional: dedicated Actor for Task Radar web search (do not reuse Instagram actor)
# APIFY_WEB_ACTOR_ID=

# ─── Task Radar (Telegram local API from telegram-rewriter process) ───────────
# TASK_RADAR_TELEGRAM_PORT=8792
# TASK_RADAR_TELEGRAM_URL=http://127.0.0.1:8792
# TASK_RADAR_TEST_USERNAME=

# ─── Groq (расшифровка аудио для Source Rewriter) ────────────────────────────
GROQ_API_KEY=
