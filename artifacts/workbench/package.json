{
  "name": "@workspace/workbench",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n \"api,ui\" -c \"blue,magenta\" \"pnpm run dev:api\" \"pnpm run dev:ui\"",
    "dev:ui": "vite",
    "dev:api": "tsx watch server/index.ts",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "concurrently": "^9.2.0",
    "tsx": "catalog:",
    "typescript": "~5.9.2",
    "vite": "catalog:"
  }
}
