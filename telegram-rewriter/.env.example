# Telegram personal account credentials
# Get from https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# OpenAI API key
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Comma-separated list of source channels to monitor
# Use @username format, e.g.: @channel1,@channel2,@channel3
SOURCE_CHANNELS=@example_channel1,@example_channel2

# Your draft/target Telegram channel where rewritten posts will be sent
# Use @username or numeric chat ID
TARGET_CHANNEL=@your_drafts_channel

# Optional: describe your writing style in detail
# If left empty, the bot will use the built-in style definition
USER_STYLE=
